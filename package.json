		"@prisma/client": "^6.18.0",
		"bcrypt": "^5.1.1",
		"compression": "^1.8.1",
		"connect-flash": "^0.1.1",
		"connect-redis": "^8.0.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"csrf-csrf": "^3.0.8",
		"dotenv": "^17.2.3",
		"ejs": "^3.0.2",
		"express": "^5.1.0",
		"express-ejs-layouts": "^2.5.1",
		"express-session": "^1.18.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.8.2",
		"jsonwebtoken": "^9.0.2",
		"moment": "^2.30.1",
		"multer": "^2.0.2",
