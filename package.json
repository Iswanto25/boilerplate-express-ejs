		"@types/cookie-parser": "^1.4.8",
		"@types/cors": "^2.8.19",
		"@types/ejs": "^3.1.5",
		"@types/express": "^5.0.3",
		"@types/express-ejs-layouts": "^2.5.4",
		"@types/express-session": "^1.18.1",
		"@types/jsonwebtoken": "^9.0.10",
