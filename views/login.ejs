<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-primary text-white text-center py-3 border-0 rounded-top-3">
                <h4 class="mb-0 fw-bold">Login</h4>
            </div>
            <div class="card-body p-4">
                <form action="/login" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="mb-3">
                        <label for="email" class="form-label fw-semibold">Email</label>
                        <input type="email" class="form-control py-2" id="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required placeholder="Masukkan email anda">
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label fw-semibold">Password</label>
                        <input type="password" class="form-control py-2" id="password" name="password" required placeholder="********">
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary py-2 fw-bold">Masuk</button>
                    </div>
                </form>
                <div class="mt-3 text-center text-muted">
                    Belum punya akun? <a href="/register" class="text-decoration-none fw-bold">Daftar sekarang</a>
                </div>
            </div>
        </div>
    </div>
</div>
