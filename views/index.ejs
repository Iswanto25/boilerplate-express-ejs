<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body text-center py-5">
                <h1 class="display-5 fw-bold text-primary">Selamat Datang di Boilerplate EJS!</h1>
                <p class="lead mt-3 text-muted">Aplikasi MVC dengan fitur lengkap, modular, dan modern.</p>
                <hr class="my-4 opacity-25">
                <div class="alert alert-info border-0 shadow-sm d-inline-block px-4">
                    <i class="bi bi-shield-check"></i> <strong>Status:</strong> Terverifikasi (JWT + Cookie)
                </div>
                <div class="mt-4 text-start bg-light p-4 rounded-3 border">
                    <h5 class="fw-bold mb-3"><i class="bi bi-person-circle me-2"></i>Informasi Akun</h5>
                    <div class="row">
                        <div class="col-sm-4 fw-bold">ID:</div>
                        <div class="col-sm-8 text-muted"><%= user.id %></div>
                        <div class="col-sm-4 fw-bold">Email:</div>
                        <div class="col-sm-8 text-muted"><%= user.email %></div>
                        <div class="col-sm-4 fw-bold">Role:</div>
                        <div class="col-sm-8"><span class="badge bg-success opacity-75"><%= user.role %></span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
