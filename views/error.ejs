<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error <%= status %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <h1 class="display-1 fw-bold text-danger"><%= status %></h1>
                <h2 class="mb-4"><%= message %></h2>
                <% if (typeof error !== 'undefined' && error && error.stack) { %>
                    <div class="text-start mt-4 p-3 bg-dark text-white rounded">
                        <pre><code><%= error.stack %></code></pre>
                    </div>
                <% } %>
                <a href="/" class="btn btn-primary btn-lg mt-4">Kembali ke Beranda</a>
            </div>
        </div>
    </div>
</body>
</html>
